# ==========================================
# Mediquery - Master Environment Config
# ==========================================

# --- Project Branding ---
PROJECT_NAME=mediquery
PROJECT_TITLE=Mediquery

# --- Backend Configuration ---

# Google Gemini API Key
# Get your API key from: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=your_api_key_here

# Anthropic API Key
# Get your API key from: https://console.anthropic.com/api
ANTHROPIC_API_KEY=your_api_key_here

# OpenAI API key
OPENAI_API_KEY=your_api_key_here

# Local Model Configuration (Ollama)
# true = local, false = cloud
USE_LOCAL_MODEL=false
# Options: qwen2.5-coder:7b, sqlcoder:7b, llama3.1, qwen3:latest
LOCAL_MODEL_NAME=qwen2.5-coder:7b
OLLAMA_HOST=http://localhost:11434

# Multi-Agent Model Configuration (for LangGraph workflow)
# Schema analysis agent
SCHEMA_NAVIGATOR_MODEL=qwen2.5-coder:7b
# SQL generation agent
SQL_WRITER_MODEL=sqlcoder:7b
# SQL validation/critique agent
CRITIC_MODEL=llama3.1

# --- AWS Bedrock Configuration ---
AWS_BEDROCK_REGION=us-west-2
# Disable IMDS (EC2 metadata service) for local development
# Prevents botocore from trying to contact 169.254.169.254 and timing out
AWS_EC2_METADATA_DISABLED=true
AWS_BEARER_TOKEN_BEDROCKyour_bedrock_api_key_here

# Bedrock Model Configuration (Claude 3.5 family - on-demand)
BEDROCK_BASE_MODEL=global.anthropic.claude-sonnet-4-6
BEDROCK_SQL_WRITER_MODEL=global.anthropic.claude-sonnet-4-6
BEDROCK_NAVIGATOR_MODEL=global.anthropic.claude-sonnet-4-6
BEDROCK_CRITIC_MODEL=global.anthropic.claude-sonnet-4-6

# Security
JWT_SECRET_KEY=_a9f2k7m3n8p4q1r6s5t2v9w8x3y7z4

# System Settings
# Chat History Auto-Deletion
# How long to keep chat messages before auto-deletion (in hours)
# Examples: 24 (1 day), 48 (2 days), 168 (1 week), 720 (30 days)
CHAT_HISTORY_RETENTION_HOURS=720

# DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG

# --- Frontend Configuration ---

# API URL (Used by Vite)
# Local: http://localhost:8001
# Docker: http://backend:8001
VITE_API_URL=http://localhost:8001
VITE_APP_TITLE=Mediquery

# --- Provider Selection ---
# Priority: Bedrock > OpenAI > Gemini > Anthropic > Local
USE_BEDROCK=true
USE_OPENAI=true
USE_GEMINI=false
USE_ANTHROPIC=false

# --- OpenAI Model Configuration ---
OPENAI_BASE_MODEL=gpt-5.2
OPENAI_SQL_WRITER_MODEL=gpt-5.2
OPENAI_NAVIGATOR_MODEL=gpt-5.2
OPENAI_CRITIC_MODEL=gpt-5.2

# --- Gemini Model Configuration ---
GEMINI_BASE_MODEL=gemini-1.5-flash
GEMINI_SQL_WRITER_MODEL=gemini-1.5-pro
GEMINI_NAVIGATOR_MODEL=gemini-1.5-flash
GEMINI_CRITIC_MODEL=gemini-1.5-flash

# --- Anthropic Model Configuration (Direct API) ---
ANTHROPIC_BASE_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_SQL_WRITER_MODEL=claude-3-5-sonnet-20241022
ANTHROPIC_NAVIGATOR_MODEL=claude-3-5-haiku-20241022
ANTHROPIC_CRITIC_MODEL=claude-3-5-haiku-20241022

# --- Local Model Configuration (Ollama) ---
LOCAL_BASE_MODEL=qwen3:latest
LOCAL_SQL_WRITER_MODEL=sqlcoder:7b
LOCAL_NAVIGATOR_MODEL=qwen2.5-coder:7b
LOCAL_CRITIC_MODEL=llama3.1

# --- Default UI Settings ---
MULTI_AGENT=true
FAST_MODE=false

# --- Docker Build Configuration ---
# Controls which dependencies are installed in Docker image
# Options: 'development' (default), 'production' (lightweight), 'local' (ML libs)
# Should match USE_BEDROCK/USE_LOCAL_MODEL settings
DOCKER_BUILD_MODE=development

# --- PostgreSQL Configuration ---
# DB name = logical database in PostgreSQL
# Schema = namespace inside a DB (unlike MySQL where DB ~= schema)
# DB_HOST: Use 'localhost' for local/hybrid development (Docker DB + local code)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=mediquery
POSTGRES_PASSWORD=postgres_password
APP_DB_NAME=mediquery_db
APP_DB_SCHEMA=mediquery_app

# OMOP analytics database + schemas
OMOP_DB_NAME=omop_db
OMOP_ETL_USER=omop_user
OMOP_ETL_PASSWORD=omop_password
OMOP_TENANT_SCHEMA=tenant_nexus_health
OMOP_VOCAB_SCHEMA=omop_vocab

# --- Pipeline Postgres Database ---
PIPELINE_DB_HOST=localhost
PIPELINE_DB_PORT=5433
PIPELINE_PROFILE=synthetic_open
ATHENA_PROFILE_ENABLED=false
VOCAB_BUNDLE_PATH=
FAIL_ON_VOCAB_GAP=true
SYNTHEA_POPULATION_SIZE=200
SYNTHEA_SEED=42

# --- Benchmarking Configuration ---
# Mode options: mode-a (deterministic), mode-b/live (SQL execution validation)
BENCHMARK_MODE=mode-a

# OMOP tenant schema used for benchmark SQL execution
BENCHMARK_DB_SCHEMA=tenant_nexus_health

# Benchmark DB target (defaults to OMOP pipeline DB)
BENCHMARK_POSTGRES_HOST=localhost
BENCHMARK_POSTGRES_PORT=5433
BENCHMARK_POSTGRES_USER=omop_user
BENCHMARK_POSTGRES_PASSWORD=omop_password
BENCHMARK_DB_NAME=omop_db

# Timeout guards for benchmark live mode
BENCHMARK_DB_CONNECT_TIMEOUT_MS=3000
BENCHMARK_DB_IDLE_TIMEOUT_MS=10000
BENCHMARK_DB_QUERY_TIMEOUT_MS=5000
