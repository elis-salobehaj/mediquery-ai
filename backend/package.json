  "scripts": {
    "build": "nest build && tsc-alias",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "db:generate": "pnpm --dir ../packages/db db:generate",
    "db:migrate": "pnpm --dir ../packages/db db:migrate",
    "db:migrate:runtime": "pnpm --dir ../packages/db db:migrate:runtime",
    "db:pull": "pnpm --dir ../packages/db db:pull",
    "db:push": "pnpm --dir ../packages/db db:push",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint:check": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:cov": "vitest run --coverage",
    "test:debug": "vitest --inspect-brk --no-file-parallelism",
    "test:e2e": "vitest run --config ./vitest.config.e2e.ts",
    "benchmark:dev": "tsx src/ai/benchmarks/dev-benchmark.ts"
  },
