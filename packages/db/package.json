{
  "name": "@mediquery/db",
  "version": "0.0.1",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "pnpm run build && pnpm node dist/migrate.js",
    "db:migrate:runtime": "pnpm node dist/migrate.js",
    "db:seed": "pnpm run build && pnpm node dist/seed.js",
    "db:pull": "drizzle-kit pull",
    "db:push": "drizzle-kit push",
    "format": "biome format --write ./src",
    "lint": "biome lint --write ./src",
    "check:ci": "biome ci ./src",
    "check": "biome check --write ./src"
  },
  "dependencies": {
    "argon2": "^0.44.0",
    "dotenv": "^17.3.1",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.1",
    "pg": "^8.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@types/node": "^22.19.15",
    "@types/pg": "^8.20.0",
    "typescript": "^5.9.3"
  },
  "packageManager": "pnpm@10.32.1+sha512.a706938f0e89ac1456b6563eab4edf1d1faf3368d1191fc5c59790e96dc918e4456ab2e67d613de1043d2e8c81f87303e6b40d4ffeca9df15ef1ad567348f2be"
}
